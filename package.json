{
  "name": "brela",
  "version": "0.1.0-alpha.1",
  "private": true,
  "workspaces": [
    "packages/core",
    "packages/cli",
    "packages/vscode-extension",
    "packages/daemon"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "dev:cli": "npm run dev --workspace=packages/cli",
    "typecheck": "npm run typecheck --workspaces",
    "test:unit": "vitest run packages/core/src/__tests__/ packages/vscode-extension/src/__tests__/",
    "test:e2e": "npm run build && tsc -p tests/tsconfig.json && node --test tests/dist/e2e/full-flow.test.js",
    "test": "npm run test:unit && npm run test:e2e"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "license": "MIT"
}
